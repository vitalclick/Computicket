# Database
DATABASE_URL=postgresql://computicket:computicket@localhost:5432/computicket?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=4000
NODE_ENV=development
JWT_SECRET=dev_unsafe_change_me_in_production
JWT_EXPIRES_IN=7d

# Social sign-in (optional — leave unset to disable). The Web Client ID
# from Google Cloud Console > APIs & Services > Credentials. The same
# value goes into the frontend env (NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID).
GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# Service ID from Apple Developer (e.g. ng.computicket.signin). Apple is
# off in dev by default; production needs the Service ID + return-URLs
# configured at developer.apple.com.
APPLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_APPLE_OAUTH_CLIENT_ID=
# Origin Apple redirects back to after authentication. Must match the
# return URL configured on the Apple Service ID exactly.
NEXT_PUBLIC_APPLE_REDIRECT_URI=https://computicket.ng/signin

# Web app URL used to build magic-link emails. Set this in production
# (or NEXT_PUBLIC_SITE_URL — whichever is set wins) so links point at
# https://computicket.ng instead of localhost.
WEB_APP_URL=http://localhost:3000

# Paystack (use test keys for development)
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me

# Email (Postmark). Leave POSTMARK_SERVER_TOKEN unset to log emails
# to stdout instead of sending them.
POSTMARK_SERVER_TOKEN=
MAIL_FROM=tickets@computicket.ng
# Public URL of the Computicket mark to inline at the top of transactional
# emails. Leave unset for wordmark-only headers (no broken-image risk in
# clients that block remote loads).
MAIL_LOGO_URL=https://computicket.ng/logo.png

# SMS (Termii). Leave TERMII_API_KEY unset to log SMSes to stdout
# instead of sending them.
TERMII_API_KEY=
TERMII_SENDER=Computicket

# Set to "1" to require a verified email before sensitive actions
# (wallet top-up, organizer creation). Off by default — existing buyers
# can keep using their accounts during the rollout, then flip this on
# once the verification flow is in production.
REQUIRE_VERIFIED_EMAIL=

# Anthropic (AI support chatbot). Leave ANTHROPIC_API_KEY unset to fall back
# to the deterministic keyword matcher.
ANTHROPIC_API_KEY=

# NFT mint vouchers. Used to HMAC-sign the (recipient, tokenId, tokenURI,
# expiresAt) payload that a deployed ERC-721 lazy-mint contract will later
# verify. Falls back to JWT_SECRET in dev.
NFT_SIGNING_KEY=

# Public base URL embedded in NFT metadata image/external_url fields.
PUBLIC_API_URL=http://localhost:4000/v1

# Public web URL used in email links (verification, password reset)
PUBLIC_WEB_URL=http://localhost:3000

# App secret used to derive the AES-256-GCM key that encrypts TOTP
# secrets at rest. Falls back to JWT_SECRET in dev.
APP_KEY=

# Sentry error tracking. Leave SENTRY_DSN unset to log unhandled errors
# to stdout only (the global filter still runs; nothing is silently
# swallowed).
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Duffel (flights). Leave DUFFEL_API_KEY unset to only return local
# Flight rows from /v1/flights. When set, results are merged.
DUFFEL_API_KEY=

# HotelBeds (hotels). Both must be set for the integration to activate;
# without them /v1/hotels returns only locally-managed Hotel rows.
HOTELBEDS_API_KEY=
HOTELBEDS_API_SECRET=

# Firebase Cloud Messaging. The whole service-account JSON belongs in a
# single env var — paste the file contents verbatim, or pre-encode as
# base64 if you don't want to deal with newline escaping in your
# deployment system. Without this, push notifications log to stdout
# but never reach a device.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
